# ─── Backend ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/feedo
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# Redis-ready (optional in dev)
REDIS_URL=redis://127.0.0.1:6379

# Razorpay — leave blank in dev to use demo payment mode.
# Get test keys at https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Shared secret for aggregator order ingestion (Zomato/Swiggy/District/middleware).
# Senders must pass it as the `x-integration-secret` header on /api/integrations/:provider/orders.
INTEGRATION_SECRET=

# Cloudinary image hosting — leave blank in dev to store uploads under local /uploads.
# Get credentials at https://console.cloudinary.com/ (Dashboard → Product Environment Credentials).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Beta/demo hosting: when "true", the customer OTP is the fixed code 123456 and is shown
# to the diner (no SMS provider needed). Leave blank/false for a real production launch.
# (Non-prod runs always behave this way regardless of this flag.)
BETA_MODE=

# ─── Frontend apps (Vite) ──────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
VITE_CUSTOMER_URL=http://localhost:5174
# Razorpay publishable key for the customer app (same as RAZORPAY_KEY_ID).
VITE_RAZORPAY_KEY_ID=
