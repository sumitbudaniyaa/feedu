{
  "name": "feedo",
  "version": "0.1.0",
  "private": true,
  "description": "Feedo — Premium Restaurant Operating System SaaS",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:all": "turbo run dev",
    "dev:admin": "turbo run dev --filter=@feedo/admin-app --filter=@feedo/backend",
    "dev:user": "turbo run dev --filter=@feedo/customer-app --filter=@feedo/backend",
    "dev:kitchen": "turbo run dev --filter=@feedo/kitchen-app --filter=@feedo/backend",
    "dev:company": "turbo run dev --filter=@feedo/super-admin-app --filter=@feedo/backend",
    "dev:landing": "turbo run dev --filter=@feedo/landing",
    "dev:backend": "turbo run dev --filter=@feedo/backend",
    "seed": "npm run seed -w @feedo/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1"
}
